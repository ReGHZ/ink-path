{
  "name": "ink-path",
  "version": "0.0.1",
  "description": "writing tools backend",
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
  "scripts": {
    "dev": "tsx watch src/api.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/api.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "pnpm typecheck && pnpm lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:status": "prisma validate",
    "db:check": "prisma migrate status",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "cpu-features",
      "protobufjs",
      "ssh2"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "amqplib": "^2.0.1",
    "argon2": "^0.44.0",
    "awilix": "^13.0.3",
    "dotenv": "^17.4.2",
    "hono": "^4.12.23",
    "jose": "^6.2.3",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "testcontainers": "^12.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
