{
  "name": "ink-path",
  "version": "0.0.1",
  "description": "writing tools backend",
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev": "tsx watch src/api.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/api.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "pnpm typecheck && pnpm lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:status": "prisma validate",
    "db:check": "prisma migrate status",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "cpu-features",
      "protobufjs",
      "ssh2"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^2.0.9",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "amqplib": "^2.0.1",
    "argon2": "^0.44.0",
    "awilix": "^13.0.5",
    "dotenv": "^17.4.2",
    "hono": "^4.12.30",
    "jose": "^6.2.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-unicorn": "^72.0.0",
    "globals": "^17.7.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "testcontainers": "^12.0.4",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
