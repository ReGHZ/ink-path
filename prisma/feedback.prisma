model ValidationResult {
  id                  String                 @id @default(uuid()) @db.Uuid
  projectId           String                 @map("project_id") @db.Uuid
  result              ValidationResultValue
  message             String                 @db.Text
  severity            ValidationSeverity
  source              ValidationResultSource
  status              ValidationResultStatus @default(open)
  validationRequestId String?                @unique @map("validation_request_id") @db.Uuid
  createdByUserId     String?                @map("created_by_user_id") @db.Uuid
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  project           Project            @relation(fields: [projectId], references: [id], onDelete: Restrict)
  createdByUser     User?              @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  validationRequest ValidationRequest? @relation("ValidationResultRequest", fields: [validationRequestId], references: [id], onDelete: Restrict)

  comments           Comment[]
  targets            ValidationResultTarget[]
  publishedByRequests ValidationRequest[] @relation("ValidationRequestResult")

  @@index([projectId, status])
  @@index([createdByUserId, createdAt])
  @@index([projectId, createdAt(sort: Desc)], map: "validation_results_project_id_created_at_idx")
  @@map("validation_results")
}

model ValidationResultTarget {
  id                 String                     @id @default(uuid()) @db.Uuid
  validationResultId String                     @map("validation_result_id") @db.Uuid
  projectId          String                     @map("project_id") @db.Uuid
  role               ValidationResultTargetRole
  createdAt          DateTime                   @default(now()) @map("created_at")

  validationResult ValidationResult @relation(fields: [validationResultId], references: [id], onDelete: Cascade)
  project          Project          @relation(fields: [projectId], references: [id], onDelete: Restrict)

  layer        ValidationResultTargetLayer?
  map          ValidationResultTargetMap?
  character    ValidationResultTargetCharacter?
  faction      ValidationResultTargetFaction?
  worldElement ValidationResultTargetWorldElement?
  event        ValidationResultTargetEvent?
  plot         ValidationResultTargetPlot?
  chapter      ValidationResultTargetChapter?

  @@index([projectId])
  @@index([validationResultId])
  @@map("validation_result_targets")
}

