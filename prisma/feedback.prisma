enum CommentType {
  general
  suggestion
  issue
  question
}

enum CommentStatus {
  active
  resolved
  archived
}

enum CommentTargetRole {
  primary
}

enum ValidationResultValue {
  consistent
  inconsistent
  warning
}

enum ValidationSeverity {
  critical
  warning
  info
}

enum ValidationResultSource {
  ai
  manual
}

enum ValidationResultStatus {
  open
  resolved
  dismissed
}

enum ValidationResultTargetRole {
  primary
  related
  context
}

model Comment {
  id                 String        @id @default(uuid()) @db.Uuid
  projectId          String        @map("project_id") @db.Uuid
  content            String        @db.Text
  type               CommentType
  status             CommentStatus @default(active)
  parentCommentId    String?       @map("parent_comment_id") @db.Uuid
  validationResultId String?       @map("validation_result_id") @db.Uuid
  createdByUserId    String        @map("created_by_user_id") @db.Uuid
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Restrict)
  createdByUser    User              @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  parentComment    Comment?          @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Restrict)
  replies          Comment[]         @relation("CommentReplies")
  validationResult ValidationResult? @relation(fields: [validationResultId], references: [id], onDelete: Restrict)

  target CommentTarget?

  @@index([parentCommentId])
  @@index([validationResultId])
  @@index([createdByUserId, createdAt])
  @@index([projectId, createdAt(sort: Desc)], map: "comments_project_id_created_at_idx")
  @@map("comments")
}

model CommentTarget {
  id        String            @id @default(uuid()) @db.Uuid
  commentId String            @unique @map("comment_id") @db.Uuid
  projectId String            @map("project_id") @db.Uuid
  role      CommentTargetRole @default(primary)
  createdAt DateTime          @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict)

  layer        CommentTargetLayer?
  map          CommentTargetMap?
  character    CommentTargetCharacter?
  faction      CommentTargetFaction?
  worldElement CommentTargetWorldElement?
  event        CommentTargetEvent?
  plot         CommentTargetPlot?
  chapter      CommentTargetChapter?

  @@index([projectId])
  @@map("comment_targets")
}

model CommentTargetLayer {
  commentTargetId String @id @map("comment_target_id") @db.Uuid
  layerId         String @map("layer_id") @db.Uuid

  commentTarget CommentTarget @relation(fields: [commentTargetId], references: [id], onDelete: Cascade)
  layer         Layer         @relation(fields: [layerId], references: [id], onDelete: Restrict)

  @@index([layerId])
  @@map("comment_target_layers")
}

model CommentTargetMap {
